# 微信公众号凭证配置
# 复制此文件为 .env，填入真实值后删除此行注释

# === 微信公众号 ===
# mp.weixin.qq.com → 设置 → 基本配置 → AppID / AppSecret
WECHAT_APPID=your_appid_here
WECHAT_APPSECRET=your_appsecret_here

# === 微信公众号可选 ===
# 默认封面 media_id（上传到微信素材库后获取，留空则自动下载文章图片）
# DEFAULT_COVER_MEDIA_ID=

# === 飞书多维表格（可选） ===
# 如果需要把发布记录写入飞书多维表格，填写以下4项
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_BITABLE_APP_TOKEN=
# FEISHU_BITABLE_TABLE_ID=

# === 定时配置 ===
# RSS 抓取间隔（小时），默认 6 小时
# FETCH_INTERVAL_HOURS=6

# === 文章配置 ===
# 文章底部作者名，留空则不设置
# DEFAULT_AUTHOR=

# === 语料库配置（可选）===
# 设为 true 启用 corpus-playbook 语料库
# ENABLE_CORPUS_PLAYBOOK=false
